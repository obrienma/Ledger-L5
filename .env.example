DATABASE_URL=postgresql+psycopg://user:password@host/ledger_l5?sslmode=require

# Phase 5 — scheduling
POLL_INTERVAL_SECONDS=60
# UUID of the one customer the automatic monthly invoice job bills. Unset ->
# the job logs an error and does nothing (see ADR 0010).
# BILLING_CUSTOMER_ID=
ENABLE_SCHEDULER=true

# Phase 6 — operator auth and dashboard
# Both required — the app fails to start if either is unset.
OPERATOR_API_TOKEN=change-me
SESSION_SECRET_KEY=change-me-too

# Phase 7 — Stripe payment collection
# Both required — the app fails to start if either is unset. Test-mode keys
# only (ADR 0013) — this system never goes near a live Stripe account.
STRIPE_SECRET_KEY=sk_test_change-me
STRIPE_WEBHOOK_SECRET=whsec_change-me
# Absolute base URL the Checkout Session's success/cancel links point back
# to. Only needs to be reachable if you're testing the redirect by hand.
APP_BASE_URL=http://localhost:8000
